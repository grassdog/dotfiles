{
  "name": "noteplan-cli",
  "version": "0.1.0",
  "description": "CLI tool for interacting with NotePlan notes",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "compile": "bun build src/index.ts --compile --outfile scripts/noteplan",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "minisearch": "^7.1.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
